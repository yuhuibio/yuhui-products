---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#2d322b] text-white py-16 px-6">

  <div class="max-w-[1300px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

    <!-- Company -->
    <div class="space-y-4">

      <h3 class="text-lg font-bold">
        XIAN YUHUI BIOTECHNOLOGY
      </h3>

      <p class="text-gray-400 text-sm leading-relaxed">
        Professional manufacturer and exporter of high-purity essential oils,
        carrier oils, and botanical extracts since 2015.
        Delivering quality and supply stability worldwide.
      </p>

      <!-- Payments -->
      <div class="pt-4">

        <p class="text-gray-200 text-sm font-semibold">
          Accepted Payments
        </p>

        <div class="flex flex-wrap gap-3 mt-3">

  <div class="bg-white rounded p-2 w-24 h-14 flex items-center justify-center">
    <img src="/images/payments/bank-transfer.png"
         class="max-h-10 max-w-full object-contain"
         alt="Bank Transfer">
  </div>

  <div class="bg-white rounded p-2 w-24 h-14 flex items-center justify-center">
    <img src="/images/payments/western-union.png"
         class="max-h-10 max-w-full object-contain"
         alt="Western Union">
  </div>

  <div class="bg-white rounded p-2 w-24 h-14 flex items-center justify-center">
    <img src="/images/payments/moneygram.png"
         class="max-h-10 max-w-full object-contain"
         alt="MoneyGram">
  </div>

  <div class="bg-white rounded p-2 w-24 h-14 flex items-center justify-center">
    <img src="/images/payments/paypal.png"
         class="max-h-10 max-w-full object-contain"
         alt="PayPal">
  </div>

  
</div>
          
      </div>
    </div>

    <!-- Links -->
    <div>
      <h3 class="text-lg font-bold mb-6">Useful Links</h3>
      <ul class="space-y-3 text-gray-400 text-sm">
        <li><a href="/" class="hover:text-white">Home</a></li>
        <li><a href="/about" class="hover:text-white">About Us</a></li>
        <li><a href="/catalogue" class="hover:text-white">Products</a></li>
        <li><a href="#" class="hover:text-white">Technical Support</a></li>
      </ul>
    </div>

    <!-- Help -->
    <div>
      <h3 class="text-lg font-bold mb-6">Let Us Help</h3>
      <ul class="space-y-3 text-gray-400 text-sm">
        <li><a href="/info/export-process" class="hover:text-white">Export Process</a></li>
        <li><a href="/info/shipping" class="hover:text-white">Shipping & Logistics</a></li>
        <li><a href="/info/quality" class="hover:text-white">Quality Assurance</a></li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="text-lg font-bold mb-6">Contact Us</h3>
      <ul class="space-y-3 text-gray-400 text-sm">
        <li>Xi'an, Shaanxi, China</li>
        <li>plantextract66@163.com</li>
        <li>WhatsApp: +86 15829552458</li>
      </ul>
    </div>

  </div>

  <!-- Bottom -->
  <div class="max-w-[1300px] mx-auto mt-12 pt-8 border-t border-gray-600 text-center text-gray-500 text-sm">
    &copy; {currentYear} XIAN YUHUI BIOTECHNOLOGY CO., LTD. All Rights Reserved.
  </div>

</footer>