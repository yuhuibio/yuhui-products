---
import '../styles/global.css'; 
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xian Yuhui Biotechnology</title>
</head>
<body class="bg-[#e5edea] text-[#4a5d4e] font-sans">
    <nav class="flex items-center justify-between px-12 py-6 w-full">
        <div class="flex items-center gap-3">
            <img src="/images/logo.png" alt="logo" class="h-10 w-auto">
            <span class="text-2xl font-bold">XIAN YUHUI BIOTECH</span>
        </div>
        <div class="flex items-center gap-8 text-lg font-medium">
            <a href="/" class="hover:text-green-800">Home</a>
            <a href="/about" class="hover:text-green-800">About Us</a>
            <div class="relative group">
                <a href="/catalogue" class="hover:text-green-800 cursor-pointer">Products ▼</a>
                <div class="absolute hidden group-hover:block top-full mt-0 w-48 z-10">
                    <div class="bg-white shadow-lg py-2 rounded border border-gray-100">
                        <a href="/essential-oils-cata" class="block px-4 py-2 hover:bg-gray-100">Single Essential oils</a>
                        <a href="/carrier-oils-cata" class="block px-4 py-2 hover:bg-gray-100">Carrier oils</a>
                        <a href="/blended-oils-cata" class="block px-4 py-2 hover:bg-gray-100">Blended oils</a>
                    </div>
                </div>
            </div>
            <a href="/news" class="hover:text-green-800">News</a>
        </div>
    </nav>
    
    <slot /> </body>
</html>