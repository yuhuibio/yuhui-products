---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro'; // 确保你已经创建了 Footer 组件

interface Props {
  title?: string;
}

const { title = "Xian Yuhui Biotechnology" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="bg-[#f8f7f4] text-[#4a5d4e] font-sans min-h-screen flex flex-col">
    
    <!-- 顶部导航 -->
    <Header />

    <!-- 页面主体内容区域 -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- 底部页脚 -->
    <Footer />

  </body>
</html>