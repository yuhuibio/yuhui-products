---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro'; // 确保你已经创建了 Footer 组件

interface Props {
  title?: string;
}

const { title = "Xian Yuhui Biotechnology" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
 <!-- ⭐ Favicon（关键） -->
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- ⭐ SEO基础优化（建议保留） -->
    <meta name="description" content="Premium essential oils supplier and manufacturer from China. Bulk essential oils, carrier oils, and botanical extracts." />

    <!-- ⭐ 浏览器主题色 -->
    <meta name="theme-color" content="#4a5d4e" />
  </head>

  <body class="bg-[#f8f7f4] text-[#4a5d4e] font-sans min-h-screen flex flex-col">
    
    <!-- 顶部导航 -->
    <Header />

    <!-- 页面主体内容区域 -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- 底部页脚 -->
    <Footer />

  </body>
</html>