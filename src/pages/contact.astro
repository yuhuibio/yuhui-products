<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | Xian Yuhui Biotechnology</title>

    <style>
        .bg-custom-green { background-color: #e5edea; }
        .text-custom-main { color: #4a5d4e; }
        .bg-custom-btn { background-color: #4a5d4e; }
        .dropdown:hover .dropdown-menu { display: block; }
        html {
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="bg-custom-green font-sans m-0 p-0">

<!-- ====================== 你的原版导航栏（完全一致） ====================== -->
<div class="bg-custom-green">
    <nav class="flex items-center justify-between px-12 py-6 w-full">
        <div class="flex items-center gap-3">
            <img src="images/logo.png" alt="logo" class="h-10 w-auto">
            <span class="text-2xl font-bold text-custom-main">XIAN YUHUI BIOTECH</span>
        </div>

        <div class="flex flex-row flex-nowrap items-center gap-8 text-lg text-gray-700 font-medium">
            <a href="/" class="hover:text-green-800">Home</a>
            <a href="/about" class="hover:text-green-800">About Us</a>

            <div class="relative group">
                <a href="/catalogue" class="hover:text-green-800 cursor-pointer">Products ▼</a>
                <div class="absolute hidden group-hover:block top-full mt-0 w-40 z-10">
                    <div class="bg-white shadow-lg py-2 rounded">
                        <a href="/Essential-oils-cata" class="block px-4 py-2 hover:bg-gray-100">Single Essential oils</a>
                        <a href="/carrier-oils-cata" class="block px-4 py-2 hover:bg-gray-100">Carrier oils</a>
                        <a href="/blended-oils-cata" class="block px-4 py-2 hover:bg-gray-100">Blended oils</a>
                    </div>
                </div>
            </div>

            <a href="/news" class="hover:text-green-800">News</a>
            <a href="#" class="hover:text-green-800">Blog</a>
            <a href="/contact" class="hover:text-green-800">Contact Us</a>
        </div>
    </nav>
</div>

<!-- ====================== Hero Section ====================== -->
<section class="relative h-[500px] flex items-center justify-center text-center text-white bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('images/contact-bg.jpg');">
    <div class="max-w-4xl px-6">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Our Essential Oil Experts</h1>
        <p class="text-lg md:text-xl mb-8 leading-relaxed">
            Looking for bulk essential oils, carrier oils,<br>
            or customized sourcing solutions?<br>
            Our team is ready to assist you.
        </p>
        <a href="#inquiry" class="bg-custom-btn text-white px-8 py-3 rounded font-medium hover:opacity-90">Get A Quote</a>
    </div>
</section>

<!-- ====================== Contact + Form 左右布局 ====================== -->
<section id="inquiry" class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-custom-main text-center mb-12">Contact & Inquiry</h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
            <!-- 左侧：联系信息（样式与 Why Work With Us 统一） -->
            <div class="lg:col-span-4 space-y-8">
                <div class="text-center">
                    <h3 class="text-custom-main font-bold text-lg mb-2">Email</h3>
                    <p class="text-gray-600">sales@yoursite.com</p>
                </div>
                <div class="text-center">
                    <h3 class="text-custom-main font-bold text-lg mb-2">WhatsApp</h3>
                    <p class="text-gray-600">+86 XXX XXXX XXXX</p>
                </div>
                <div class="text-center">
                    <h3 class="text-custom-main font-bold text-lg mb-2">Phone</h3>
                    <p class="text-gray-600">+86 XXX XXXX XXXX</p>
                </div>
                <div class="text-center">
                    <h3 class="text-custom-main font-bold text-lg mb-2">Address</h3>
                    <p class="font-bold text-gray-600">XIAN YUHUI BIOTECHNOLOGY CO., LTD</p>
                    <p class="text-gray-600">Xi'an, Shaanxi, China</p>
                </div>
            </div>

            <!-- 右侧：询盘表单 -->
            <div class="lg:col-span-8 bg-gray-50 p-8 md:p-10 rounded-xl shadow">
                <h4 class="font-semibold text-gray-700 mb-4">Basic Information</h4>
                <form>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
                            <input type="text" required class="w-full border border-gray-300 rounded px-4 py-2">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Company Name *</label>
                            <input type="text" required class="w-full border border-gray-300 rounded px-4 py-2">
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1"> Email *</label>
                            <input type="email" required class="w-full border border-gray-300 rounded px-4 py-2">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Country *</label>
                            <input type="text" required class="w-full border border-gray-300 rounded px-4 py-2">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Product Interested In *</label>
                        <select required class="w-full border border-gray-300 rounded px-4 py-2">
                            <option value="">Select</option>
                            <option>Essential Oils</option>
                            <option>Carrier Oils</option>
                            <option>Blended Oils</option>
                            <option>Custom Formulation</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Estimated Quantity</label>
                        <select class="w-full border border-gray-300 rounded px-4 py-2">
                            <option>Sample</option>
                            <option>1-25kg</option>
                            <option>25-200kg</option>
                            <option>200kg+</option>
                        </select>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                        <textarea rows="5" placeholder="Please tell us your requirements." class="w-full border border-gray-300 rounded px-4 py-2"></textarea>
                    </div>

                    <button type="submit" class="w-full bg-custom-btn text-white font-medium py-3 rounded hover:opacity-90">Request A Quote</button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- ====================== Why Work With Us ====================== -->
<section class="py-16 max-w-7xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-custom-main text-center mb-12">Why Work With Us</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        <div>
            <h3 class="font-bold text-lg text-custom-main mb-2">Extensive Product Range</h3>
            <p class="text-gray-600">100+ essential oils and carrier oils available.</p>
        </div>
        <div>
            <h3 class="font-bold text-lg text-custom-main mb-2">Flexible Packaging</h3>
            <p class="text-gray-600">From samples to bulk drums.</p>
        </div>
        <div>
            <h3 class="font-bold text-lg text-custom-main mb-2">Quality Control</h3>
            <p class="text-gray-600">GC-MS testing and quality documentation available.</p>
        </div>
        <div>
            <h3 class="font-bold text-lg text-custom-main mb-2">Global Export Experience</h3>
            <p class="text-gray-600">Serving customers worldwide.</p>
        </div>
    </div>
</section>

<!-- ====================== FAQ ====================== -->
<section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-custom-main text-center mb-10">Frequently Asked Questions</h2>
        <div class="space-y-4">
            <div class="bg-white p-5 rounded-lg shadow">
                <h4 class="font-bold text-custom-main mb-1">MOQ?</h4>
                <p class="text-gray-600">MOQ depends on product type and packaging requirements.</p>
            </div>
            <div class="bg-white p-5 rounded-lg shadow">
                <h4 class="font-bold text-custom-main mb-1">Samples Available?</h4>
                <p class="text-gray-600">Yes, samples are available for evaluation.</p>
            </div>
            <div class="bg-white p-5 rounded-lg shadow">
                <h4 class="font-bold text-custom-main mb-1">Documentation?</h4>
                <p class="text-gray-600">COA, MSDS, GC-MS, TDS and other documents are available.</p>
            </div>
            <div class="bg-white p-5 rounded-lg shadow">
                <h4 class="font-bold text-custom-main mb-1">Shipping?</h4>
                <p class="text-gray-600">Worldwide shipping by air, sea and courier.</p>
            </div>
        </div>
    </div>
</section>

<!-- ====================== Bottom CTA Banner ====================== -->
<section class="py-16 bg-custom-green text-custom-main text-center">
    <div class="max-w-4xl mx-auto px-6">
        <h3 class="text-2xl md:text-3xl font-bold mb-3">Ready to Source Premium Essential Oils?</h3>
        <p class="mb-6 text-lg">Contact us today for pricing, samples and technical documents.</p>
        <a href="#inquiry" class="bg-custom-btn text-white px-8 py-3 rounded font-medium hover:opacity-90">Get A Free Quote</a>
    </div>
</section>