---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Xian Yuhui Biotechnology">

  <!-- HERO -->
  <section
    class="relative h-[500px] flex items-center justify-center text-center text-white bg-cover bg-center"
    style="background-image: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.55)), url('/images/contact-bg.jpg');"
  >
    <div class="max-w-4xl px-6">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Contact Our Essential Oil Experts
      </h1>

      <p class="text-lg md:text-xl mb-8 leading-relaxed text-gray-100">
        Looking for bulk essential oils, carrier oils, or customized sourcing solutions?<br />
        Our team is ready to assist you.
      </p>

      <a
        href="#inquiry"
        class="bg-[#4a5d4e] text-white px-8 py-3 rounded font-medium hover:opacity-90 transition"
      >
        Get A Quote
      </a>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section id="inquiry" class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-10">

      <!-- LEFT INFO -->
      <div class="lg:col-span-4 space-y-10">

        <div class="text-center">
          <h3 class="text-[#4a5d4e] font-bold text-lg mb-2">Email</h3>
          <p class="text-gray-600">plantextract66@163.com</p>
        </div>

        <div class="text-center">
          <h3 class="text-[#4a5d4e] font-bold text-lg mb-2">WhatsApp / WeChat</h3>
          <p class="text-gray-600">+86 15829552458</p>
        </div>

        <div class="text-center">
          <h3 class="text-[#4a5d4e] font-bold text-lg mb-2">Phone</h3>
          <p class="text-gray-600">+86 29 86259572</p>
        </div>

        <div class="text-center">
          <h3 class="text-[#4a5d4e] font-bold text-lg mb-2">Address</h3>
          <p class="font-semibold text-gray-700">
            XIAN YUHUI BIOTECHNOLOGY CO., LTD
          </p>
          <p class="text-gray-600">
            Xi'an, Shaanxi, China
          </p>
        </div>

      </div>

      <!-- RIGHT FORM -->
      <div class="lg:col-span-8 bg-gray-50 p-8 md:p-10 rounded-xl shadow">

        <h2 class="text-2xl font-bold text-[#4a5d4e] mb-6">
          Send Us an Inquiry
        </h2>

        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="grid grid-cols-1 md:grid-cols-2 gap-5"
        >

          <!-- Web3Forms Access Key -->
          <input
            type="hidden"
            name="access_key"
            value="5807e193-4a84-4b76-8713-b2b85da12526"
          />

          <!-- Email Subject -->
          <input
            type="hidden"
            name="subject"
            value="New Inquiry From Yuhuibiotec Website"
          />

          <!-- Anti Spam -->
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display:none"
          />

          <!-- Name -->
          <input
            type="text"
            name="name"
            required
            placeholder="Your Name"
            class="p-3 border rounded focus:outline-none focus:ring-2 focus:ring-[#4a5d4e]"
          />

          <!-- Email -->
          <input
            type="email"
            name="email"
            required
            placeholder="Email Address"
            class="p-3 border rounded focus:outline-none focus:ring-2 focus:ring-[#4a5d4e]"
          />

          <!-- Company -->
          <input
            type="text"
            name="company"
            placeholder="Company Name"
            class="p-3 border rounded focus:outline-none focus:ring-2 focus:ring-[#4a5d4e] md:col-span-2"
          />

          <!-- Phone -->
          <input
            type="text"
            name="phone"
            placeholder="WhatsApp / Phone Number"
            class="p-3 border rounded focus:outline-none focus:ring-2 focus:ring-[#4a5d4e] md:col-span-2"
          />

          <!-- Message -->
          <textarea
            rows="6"
            name="message"
            required
            placeholder="Your Message (Product Name, Quantity, Destination Country, MOQ, etc.)"
            class="p-3 border rounded focus:outline-none focus:ring-2 focus:ring-[#4a5d4e] md:col-span-2"
          ></textarea>

          <!-- Submit -->
          <button
            type="submit"
            class="bg-[#4a5d4e] text-white py-3 rounded hover:opacity-90 transition md:col-span-2"
          >
            Submit Inquiry
          </button>

        </form>

      </div>

    </div>
  </section>

</Layout>