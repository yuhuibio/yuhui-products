---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Catalog | Xian Yuhui Biotechnology">

<!-- HERO -->
<section class="max-w-7xl mx-auto px-5 py-10">
  <div class="grid lg:grid-cols-2 gap-12 items-center">

    <div class="space-y-4">
      <h1 class="text-4xl font-bold text-[#3d4d45]">
        Pure Oils for Global Applications
      </h1>

      <p class="text-lg text-[#3d4d45]/80">
        Essential oils, carrier oils, and blended oils for cosmetics, personal care, fragrance, and industrial formulation.
      </p>

      <button class="bg-[#3d4d45] text-white px-8 py-3 rounded hover:bg-emerald-900 transition">
        Inquire Now
      </button>
    </div>

    <div class="aspect-[16/10] rounded-2xl overflow-hidden shadow-xl">
      <img src="/images/your-image-url.jpg" class="w-full h-full object-cover" />
    </div>

  </div>
</section>

<!-- PRODUCT CATEGORIES -->
<section class="py-20 px-6 bg-[#f2eede]">
  <div class="max-w-7xl mx-auto">

    <h2 class="text-3xl font-light mb-2 text-[#3d4d45]">Product Categories</h2>
    <p class="text-slate-600 mb-10">
      Explore our range of botanical oils for different formulation needs.
    </p>

    <div class="grid md:grid-cols-3 gap-8">

      <a href="/essential-oils" class="bg-white border hover:border-[#3d4d45] transition">
        <img src="/images/path-to-distillation-image.jpg" class="aspect-[4/3] object-cover w-full" />
        <div class="p-6">
          <h3 class="text-xl text-[#3d4d45]">Essential Oils</h3>
        </div>
      </a>

      <a href="/carrier-oils" class="bg-white border hover:border-[#3d4d45] transition">
        <img src="/images/path-to-pressing-image.jpg" class="aspect-[4/3] object-cover w-full" />
        <div class="p-6">
          <h3 class="text-xl text-[#3d4d45]">Carrier Oils</h3>
        </div>
      </a>

      <a href="/blended-oils" class="bg-white border hover:border-[#3d4d45] transition">
        <img src="/images/path-to-blending-image.jpg" class="aspect-[4/3] object-cover w-full" />
        <div class="p-6">
          <h3 class="text-xl text-[#3d4d45]">Blended Oils</h3>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- INDUSTRIES -->
<section class="py-20 max-w-7xl mx-auto px-6">

  <h2 class="text-3xl font-bold mb-8 text-[#3d4d45]">Industries We Serve</h2>

  <div class="grid md:grid-cols-3 gap-6">

    {[
      ["Cosmetics & Skincare", "skincare.jpg"],
      ["Personal Care", "personalcare.jpg"],
      ["Aromatherapy", "aromatherapy.jpg"],
      ["Hair Care", "haircare.jpg"],
      ["Soap Making", "soapmake.jpg"],
      ["Candles & Fragrance", "candles.jpg"]
    ].map(([title, img]) => (
      <div class="relative h-64 overflow-hidden rounded-xl shadow group">
        <img src={`/images/${img}`} class="absolute w-full h-full object-cover group-hover:scale-105 transition" />
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="absolute bottom-4 left-4 text-white font-semibold">
          {title}
        </div>
      </div>
    ))}

  </div>
</section>

<!-- LEAD FORM -->
<section class="bg-[#F8F6F1] py-20 px-6">

  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-10">

    <div class="bg-white p-8 rounded-xl shadow">
      <h3 class="text-2xl font-bold mb-4 text-[#3d4d45]">
        Request Full Product Catalog
      </h3>

      <p class="mb-6 text-slate-600">
        Get COA, MSDS, wholesale pricing and full specifications.
      </p>

      <form class="space-y-4">
        <input class="w-full p-3 border rounded" placeholder="Full Name" />
        <input class="w-full p-3 border rounded" placeholder="Email" />
        <textarea class="w-full p-3 border rounded" placeholder="Message"></textarea>

        <button class="w-full bg-[#3d4d45] text-white py-3 rounded hover:bg-emerald-900">
          Send Request
        </button>
      </form>
    </div>

    <div class="bg-white p-8 rounded-xl shadow">
      <h3 class="text-2xl font-bold text-[#3d4d45]">
        WhatsApp Inquiry
      </h3>

      <a class="block mt-6 bg-green-500 text-white text-center py-3 rounded"
         href="https://wa.me/XXXXXXXXXXX">
        Chat on WhatsApp
      </a>

      <p class="mt-6 text-sm text-slate-600">
        Response within 1–3 hours
      </p>
    </div>

  </div>

</section>

</Layout>