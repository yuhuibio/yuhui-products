---
import Layout from '../layouts/Layout.astro';
import { allNews } from '../data/news.js';
---

<Layout title="News Detail | Yuhui Biotechnology">

  <!-- BANNER -->
  <section class="h-[250px] flex items-center px-10 bg-[#e5edea]">
    <h1 class="text-4xl font-bold text-[#4a5d4e]">News Detail</h1>
  </section>

  <!-- CONTENT -->
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div id="newsDetail"></div>
  </div>

  <!-- SCRIPT（保留你的动态渲染逻辑） -->
  <script is:inline define:vars={{ allNews }}>

    function getId() {
      const id = new URLSearchParams(window.location.search).get("id");
      return id ? Number(id) : null;
    }

    function renderDetail() {
      const id = getId();
      const el = document.getElementById("newsDetail");

      if (!id || !el) {
        if (el) el.innerHTML = "<p class='text-red-500'>Missing news id</p>";
        return;
      }

      const news = allNews.find(n => n.id === id);

      if (!news) {
        el.innerHTML = "<p class='text-red-500'>News not found</p>";
        return;
      }

      const highlight = new Set([
        "A Year in Review: Highlights & Achievements",
        "Here are a few highlights from 2024:",
        "Looking Ahead: Exciting Plans for 2025",
        "Wishing You a Year of Wellness and Joy"
      ]);

      const lines = news.content.split(/\n+/);

      const contentHTML = lines.map(line => {
        const text = line.trim();
        if (!text) return "";

        if (highlight.has(text)) {
          return `<h2 class="text-2xl font-bold text-[#4a5d4e] mt-8 mb-3">${text}</h2>`;
        }

        return `<p class="mb-3 leading-7 text-gray-700">${text}</p>`;
      }).join("");

      el.innerHTML = `
        <h1 class="text-3xl font-bold mb-3 text-[#4a5d4e]">${news.title}</h1>
        <p class="text-gray-500 mb-6">${news.date}</p>
        <img src="${news.image}" class="w-full rounded-xl mb-8"/>
        <div>${contentHTML}</div>
      `;
    }

    document.addEventListener("DOMContentLoaded", renderDetail);

  </script>

</Layout>