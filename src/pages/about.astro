            </div>
            <p class="text-sm text-slate-400 mt-4 italic text-right">Commitment to quality from the source</p>
        </div>

    </div>
</section>
<!-- 生产与质量控制板块 (Production & Quality Control System) - 左图右文布局 -->
<section class="max-w-7xl mx-auto px-6 py-12">
