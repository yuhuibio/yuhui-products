---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- HERO SECTION -->
<div class="relative w-full h-[420px] mb-24 overflow-hidden">

  <img
    src="/images/1111.jpg"
    alt="Company Building"
    class="absolute inset-0 w-full h-full object-cover"
  />

  <!-- overlay -->
  <div class="absolute inset-0 bg-black/10"></div>

  <!-- bottom banner -->
  <div class="absolute bottom-0 left-0 right-0 max-w-5xl mx-auto px-6 translate-y-1/2 z-10">

    <div class="bg-[#4a5d4e] py-6 text-center">
      <h2 class="text-white text-4xl font-bold">About Us</h2>
    </div>

    <div class="bg-[#e5edea] py-8 text-center shadow-lg">
      <h3 class="text-[#4a5d4e] text-3xl font-bold">
        XIAN YUHUI BIOTECHNOLOGY
      </h3>
    </div>

  </div>
</div>

<!-- INTRO TEXT -->
<section class="max-w-4xl mx-auto px-6 py-16 text-center">
  <p class="text-xl lg:text-2xl text-slate-700 leading-relaxed font-light">
    We combine in-house manufacturing in China with locally sourced raw materials and selected imported essential oils to provide a stable and flexible supply for global B2B customers.
  </p>
</section>

<!-- COMPANY SECTION -->
<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid lg:grid-cols-2 gap-16 items-center">

    <!-- TEXT -->
    <div class="space-y-6">
      <h2 class="text-3xl font-bold text-[#4a5d4e]">The Company</h2>

      <p class="text-slate-600 text-lg leading-relaxed">
        We are a China-based essential oil supplier and manufacturer with over 11 years of experience in in-house processing and structured sourcing of raw materials.
      </p>

      <p class="text-slate-600 text-lg leading-relaxed">
        Our essential oils are widely used in cosmetics, personal care, fragrance, and related industries. We work closely with importers and brands worldwide.
      </p>
    </div>

    <!-- IMAGE -->
    <div class="w-full">
      <img
        src="/images/banner-5.jpg"
        alt="Laboratory"
        class="w-full h-[500px] rounded-2xl shadow-xl object-cover"
      />
      <p class="text-sm text-slate-400 mt-4 italic text-right">
        In-house quality control and manufacturing excellence
      </p>
    </div>

  </div>
</section>

<!-- FLEXIBLE SUPPLY -->
<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid lg:grid-cols-2 gap-16 items-center">

    <!-- IMAGE -->
    <div>
      <img
        src="/images/banner-4.jpg"
        alt="Business Partnership"
        class="w-full h-[500px] rounded-2xl shadow-xl object-cover"
      />
      <p class="text-sm text-slate-400 mt-4 italic">
        Committed to collaborative growth and partnership
      </p>
    </div>

    <!-- TEXT -->
    <div class="space-y-6">
      <h2 class="text-3xl font-bold text-[#4a5d4e]">
        Flexible Supply for All Business Sizes
      </h2>

      <p class="text-slate-600 text-lg leading-relaxed">
        We provide flexible essential oil supply solutions tailored to different market needs.
      </p>

      <p class="text-slate-600 text-lg leading-relaxed">
        We support customized specifications, packaging options, and order volumes for global clients.
      </p>
    </div>

  </div>
</section>

<!-- SOURCE TO PRODUCT -->
<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid lg:grid-cols-2 gap-16 items-center">

    <div class="space-y-6">
      <h2 class="text-3xl font-bold text-[#4a5d4e]">
        From Growers to Final Product
      </h2>

      <p class="text-slate-600 text-lg leading-relaxed">
        All high-quality essential oils come from carefully selected botanical raw materials.
      </p>

      <p class="text-slate-600 text-lg leading-relaxed">
        We maintain long-term relationships with growers to ensure stable and reliable supply.
      </p>
    </div>

    <img
      src="/images/grower.jpg"
      class="w-full h-[500px] rounded-2xl shadow-xl object-cover"
      alt="Botanical Farming"
    />

  </div>
</section>

<!-- QUALITY CONTROL -->
<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid lg:grid-cols-2 gap-16 items-center">

    <img
      src="/images/lab-testing.jpg"
      class="w-full h-[500px] rounded-2xl shadow-xl object-cover"
      alt="Lab Testing"
    />

    <div class="space-y-6">
      <h2 class="text-3xl font-bold text-[#4a5d4e]">
        Production & Quality Control System
      </h2>

      <p class="text-slate-600 text-lg leading-relaxed">
        We operate GMP-standard workshops with strict quality control systems.
      </p>

      <p class="text-slate-600 text-lg leading-relaxed">
        Each batch undergoes inspection from raw materials to final packaging.
      </p>

      <p class="text-slate-600 text-lg leading-relaxed">
        Warehousing systems ensure product stability and traceability.
      </p>
    </div>

  </div>
</section>

<!-- CONTACT -->
<section class="bg-[#e5edea] py-20 px-6">
  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-start">

    <div class="space-y-6">
      <h2 class="text-3xl font-bold text-[#4a5d4e]">
        Contact our sales team
      </h2>

      <p class="text-slate-700 text-lg leading-relaxed">
        Work with a professional essential oil manufacturer and explore tailored solutions for your business.
      </p>

      <img
        src="/images/contact-us.jpg"
        class="w-full rounded-2xl shadow-lg"
        alt="Sales Team"
      />
    </div>

    <!-- FORM -->
    <div class="bg-white p-8 rounded-2xl shadow-sm">
      <h3 class="text-2xl font-bold text-[#4a5d4e] mb-6">
        Connect with us
      </h3>

      <form class="space-y-4">
        <input class="w-full p-3 border rounded-lg" placeholder="Your Name" />
        <input class="w-full p-3 border rounded-lg" placeholder="Your Email" />
        <input class="w-full p-3 border rounded-lg" placeholder="Business" />

        <select class="w-full p-3 border rounded-lg">
          <option>United States - US</option>
        </select>

        <textarea class="w-full p-3 border rounded-lg" rows="4" placeholder="Message"></textarea>

        <button class="w-full bg-[#4a5d4e] text-white py-3 rounded-lg font-bold">
          SUBMIT
        </button>
      </form>
    </div>

  </div>
</section>

</Layout>