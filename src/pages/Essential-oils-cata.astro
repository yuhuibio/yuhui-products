---
import Layout from '../layouts/Layout.astro';
import products from '../data/oils.json';
---

<Layout title="Single Essential Oils | Xian Yuhui Biotechnology">

  <!-- Hero Banner -->
  <section class="py-10 mb-16">
    <h2 class="text-center text-4xl font-bold mb-10 text-gray-900">
      Bulk Single Essential Oils
    </h2>

    <div class="relative w-full overflow-hidden">
      <img src="/images/banner-oils.jpg" alt="Banner" class="w-full h-auto object-cover" />

      <div class="absolute inset-0 flex flex-col items-center justify-center text-black text-center px-4">
        <h3 class="text-6xl font-bold uppercase mb-6 tracking-wider">
          100% Pure & Natural
        </h3>
        <p class="text-3xl font-normal tracking-wide">
          Quality You Can Trust | Supply You Can Rely On
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <div class="max-w-[1400px] mx-auto px-6 mb-20 flex gap-12">

    <!-- Sidebar -->
    <aside class="w-48 flex-shrink-0">
      <ul class="space-y-5">
        <li>
          <a href="/essential-oils-cata" class="font-bold border-l-2 border-black pl-3 text-black">
            All Single Essential Oils
          </a>
        </li>
        <li><a href="#" class="text-gray-400 hover:text-black">Floral Oils</a></li>
        <li><a href="#" class="text-gray-400 hover:text-black">Citrus Oils</a></li>
        <li><a href="#" class="text-gray-400 hover:text-black">Herbal Oils</a></li>
        <li><a href="#" class="text-gray-400 hover:text-black">Wood & Resin</a></li>
        <li><a href="#" class="text-gray-400 hover:text-black">Spice Oils</a></li>
      </ul>
    </aside>

    <!-- Product Grid -->
    <main class="flex-grow">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        {products.map((p) => (
          <div class="border border-gray-100 p-5 rounded-lg flex flex-col text-center hover:shadow-lg transition">

            <div class="h-64 w-full bg-gray-50 mb-4 flex items-center justify-center rounded overflow-hidden">
              <img
                src={p.img}
                alt={p.name}
                class="max-h-full max-w-full object-contain"
              />
            </div>

            <h4 class="font-medium text-gray-800 mt-auto">{p.name}</h4>
            <p class="text-xs text-gray-400 italic">{p.latin}</p>
            <p class="text-xs text-gray-500 mb-4">{p.method}</p>

            <a
              href={`/products/${p.slug}`}
              class="w-full bg-[#4a5d4e] text-white py-2 rounded text-xs hover:bg-emerald-900 transition"
            >
              View Details
            </a>

          </div>
        ))}

      </div>
    </main>

  </div>

</Layout>