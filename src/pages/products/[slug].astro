---
import Layout from '../../layouts/Layout.astro';
import oils from "../../data/oils.json";
import carriers from "../../data/carrier-oils.json";
import blends from "../../data/blended-oils.json";

// 1. 专门用于 getStaticPaths 的合并逻辑
export async function getStaticPaths() {
  const pathsData = [...oils, ...carriers, ...blends];
  return pathsData.map((p) => ({
    params: { slug: p.slug },
    props: { product: p }
  }));
}

// 2. 页面主体逻辑
const { product } = Astro.props;

if (!product) {
  throw new Error("Product not found");
}

// 3. 在页面主体内再次定义一份数据，仅供页面渲染使用
const allProducts = [...oils, ...carriers, ...blends];

// ... 其余逻辑保持不变 ...
function generateDescription(p) {
  const base = `${p.name} (INCI: ${p.latin})`;
  if (p.category === "carrier" || p.type === "carrier") {
    return `${base} is a premium carrier oil derived from natural botanical sources. It is widely used in skincare, cosmetic formulations, and aromatherapy applications as a base ingredient for dilution and formulation support.\n\nIt is produced using ${p.method || "carefully controlled extraction methods"} to ensure purity, stability, and excellent skin compatibility.\n\nCarrier oils serve as essential base materials for blending essential oils and improving formulation safety and absorption.`;
  }
  if (p.category === "blend" || p.type === "blend") {
    return `${base} is a professionally formulated aromatic blend designed for targeted wellness applications.\n\nIt combines carefully selected natural ingredients to create a balanced aroma profile suitable for diffusion, massage, spa treatments, and functional aromatherapy use.\n\nThis blend is ready to use and optimized for emotional and environmental wellness support.`;
  }
  return `${base} is a natural essential oil extracted from ${p.origin || "selected botanical sources"} using ${p.method || "controlled extraction methods"}.\n\nIt is widely used in aromatherapy, fragrance formulation, skincare, and cosmetic applications due to its characteristic aroma and plant-derived properties.\n\nIt blends well with carrier oils and other essential oils for professional formulation and product development.`;
}

const description = generateDescription(product);

const techFields = [
  ["Latin Name", product.latin],
  ["Category", product.category],
  ["Origin", product.origin],
  ["Extraction Method", product.method],
  ["Plant Part", product.partUsed],
  ["Appearance", product.appearance],
  ["Aroma", product.aroma],
  ["CAS / Code", product.cas || product.odor],
  ["Relative Density", product.relativeDensity],
  ["Refractive Index", product.refractiveIndex],
  ["Optical Rotation", product.opticalRotation],
  ["Solubility", product.solubility],
  ["Shelf Life", product.shelfLife],
  ["Storage Conditions", product.storageConditions]
].filter(([_, v]) => v);

const relatedProducts = allProducts
  .filter(p => p.category === product.category && p.slug !== product.slug)
  .slice(0, 6);
---

<Layout title={`${product.name} | Yuhui Biotechnology`}>
  <section class="max-w-6xl mx-auto px-4 py-10">
    <div class="grid md:grid-cols-2 gap-10">
      <img src={product.img} alt={product.name} class="w-full h-[400px] object-contain border rounded" />
      <div>
        <h1 class="text-4xl font-bold text-[#4a5d4e] mb-6">{product.name}</h1>
        <p class="mb-4"><b>INCI:</b> {product.latin}</p>
        <a href="/contact" class="inline-block bg-[#4a5d4e] text-white px-6 py-3 rounded">Send Inquiry</a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-10">
    <h2 class="text-2xl font-bold mb-4 text-[#4a5d4e]">Product Description</h2>
    <p class="leading-relaxed text-gray-700 whitespace-pre-line">{description}</p>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-10">
    <h2 class="text-2xl font-bold mb-6 text-[#4a5d4e]">Technical Data</h2>
    <div class="grid md:grid-cols-2 gap-4 text-sm text-gray-700">
      {techFields.map(([k, v]) => (
        <p><b>{k}:</b> {v}</p>
      ))}
    </div>
  </section>
</Layout>