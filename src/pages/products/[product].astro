---
import Footer from '../../components/Footer.astro'; 
import allOils from '../../data/oils.json';

const { product } = Astro.params;
const targetSlug = product;

// 匹配产品，内联slug逻辑
const currentOil = allOils.find(item => {
  const itemSlug = item.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/gi, '');
  return itemSlug === targetSlug;
});

// 静态路由，内联生成slug
export async function getStaticPaths() {
  return allOils.map(oil => ({
    params: { 
      product: oil.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/gi, '') 
    }
  }));
}

if (!currentOil) {
  return Astro.redirect('/Essential-oils-cata.html');
}

// ✅ 产品描述函数
function generateDescription(p) {
  if (p.name.toLowerCase().includes("carrier")) {
    return `${p.name} is derived from ${p.latin}. It is a gentle and moisturizing carrier oil, perfect for skincare, massage, and as a base for essential oil blends.`;
  }
  const aroma = p.odor || "pure aromatic";
  return `${p.name} is derived from ${p.latin} and features a ${aroma} aroma. It is widely used in aromatherapy, personal care, skincare, and fragrance formulations. Known for its pure and natural properties, it is a versatile ingredient for wellness and cosmetic applications.`;
}

const productDescription = generateDescription(currentOil);

// ✅ 推荐产品（自动排除自己）
const allProducts = [
  { name: "Lavender Oil", slug: "lavender-oil", img: "/images/lavender-oil.jpg" },
  { name: "Peppermint Oil", slug: "peppermint-oil", img: "/images/peppermint-oil.jpg" },
  { name: "Eucalyptus Oil", slug: "eucalyptus-oil", img: "/images/eucalyptus-oil.jpg" },
  { name: "Lemon Oil", slug: "lemon-oil", img: "/images/lemon-oil.jpg" },
  { name: "Tea Tree Oil", slug: "tea-tree-oil", img: "/images/tea-tree-oil.jpg" },
  { name: "Rosemary Oil", slug: "rosemary-oil", img: "/images/rosemary-oil.jpg" },
  { name: "Cedarwood Oil", slug: "cedarwood-oil", img: "/images/cedarwood-oil.jpg" },
  { name: "Bergamot Oil", slug: "bergamot-oil", img: "/images/bergamot-oil.jpg" },
];

const relatedProducts = allProducts.filter(item => {
  return item.slug !== targetSlug;
});
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{currentOil.name} | Xian Yuhui Biotechnology</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .bg-custom-green { background-color: #e5edea; }
        .text-custom-main { color: #4a5d4e; }
        .bg-custom-btn { background-color: #4a5d4e; }
        .dropdown:hover .dropdown-menu { display: block; }

        * { box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: white; color: #333; margin: 0; padding: 0; }
        
        .detail-container {
            max-width: 1400px;
            margin: 60px auto;
            padding: 0 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
        }
        .detail-img {
            width: 100%;
            height: 450px;
            object-fit: contain;
            border: 1px solid #d0d0d0;
            padding: 20px;
            background: #fff;
        }
        .detail-info h1 {
            font-size: 26px;
            font-weight: 600;
            color: #4a5d4e;
            margin-bottom: 30px;
        }
        .detail-row {
            font-size: 16px;
            margin: 18px 0;
            line-height: 1.6;
        }
        .detail-row strong {
            display: inline-block;
            width: 180px;
            font-weight: 600;
        }
        .dropdown {
            position: relative;
            display: inline-block;
        }
        .dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            z-index: 999;
        }
        .dropdown:hover .dropdown-menu {
            display: block;
        }
    </style>
</head>
<body class="bg-white font-sans">

<nav style="display:flex; align-items:center; justify-content:space-between; padding:24px 48px; flex-wrap:nowrap;">
    <div style="display:flex; align-items:center; gap:10px;">
        <img src="/images/logo.png" alt="logo" style="height:40px; width:auto; max-height:40px;">
        <span style="font-size:24px; font-weight:bold; color:#4a5d4e;">XIAN YUHUI BIOTECH</span>
    </div>
    <div style="display:flex; align-items:center; gap:32px; white-space:nowrap;">
        <a href="/about.html" style="color:#000000; text-decoration:none; font-size:16px;">About Us</a>
        <div class="dropdown">
            <a href="/catalogue.html" style="color:#000000; text-decoration:none; font-size:16px;">Products ▼</a>
            <div class="dropdown-menu">
                <div style="background:white; box-shadow:0 2px 8px #ddd; border-radius:6px; padding:8px 0;">
                    <a href="/Essential%20oils%20cata.html" style="display:block; padding:8px 16px; color:blue; text-decoration:none;">Essential oils</a>
                    <a href="#" style="display:block; padding:8px 16px; color:blue; text-decoration:none;">Carrier oils</a>
                    <a href="#" style="display:block; padding:8px 16px; color:blue; text-decoration:none;">Blends oils</a>
                </div>
            </div>
        </div>
        <a href="#" style="color:#000000; text-decoration:none; font-size:16px;">News & Blog</a>
        <a href="#" style="color:#000000; text-decoration:none; font-size:16px;">Applications</a>
        <a href="#" style="color:#000000; text-decoration:none; font-size:16px;">Contact Us</a>
    </div>
</nav>

<div style="width:100%;">
    <div style="max-width:1400px; margin:0 auto; padding:0 40px; margin:40px auto 20px auto;">
        <h2 style="text-align:center; font-size:40px; font-weight:bold; color:#111; margin:0;">Bulk Single Essential oils</h2>
    </div>
    <div style="width:100%; position:relative; overflow:hidden;">
        <img src="/images/banner-oils.jpg" style="width:100%; height:auto; display:block;">
        <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center;">
            <h3 style="font-size:60px; font-weight:bold; text-transform:uppercase; margin:0 0 24px 0; color:#000;">100% Pure & Natural</h3>
            <p style="font-size:32px; margin:0; color:#000;">Quality You Can Trust | Supply You Can Rely On</p>
        </div>
    </div>
</div>

<div class="detail-container">
    <div>
        <img src={currentOil.img} class="detail-img" alt={currentOil.name}>
    </div>
    <div class="detail-info">
        <h1>{currentOil.name}</h1>
        
       <div class="detail-row"><strong>Botanical Name:</strong> {currentOil.latin}</div>
<div class="detail-row"><strong>Aroma:</strong> {currentOil.aroma}</div>
        <div class="detail-row"><strong>Origin:</strong> {currentOil.origin}</div>
        <div class="detail-row"><strong>Part Used:</strong> {currentOil.partUsed}</div>
        <div class="detail-row"><strong>Extraction Method:</strong> {currentOil.method}</div>
    </div>
</div>

<!-- 产品规格表 -->
<div style="max-width:1400px; margin:80px auto; padding:0 40px;">
  <h3 style="font-size:24px; color:#4a5d4e; margin:0 0 20px 0; padding-bottom:12px; border-bottom:1px solid #ddd; font-weight:normal;">
    Specifications Sheet
  </h3>

  <div style="display:grid; grid-template-columns: 1fr 1fr; column-gap: 80px; row-gap: 20px; font-size:16px; color:#222;">
    <div>Appearance: {currentOil.appearance ?? '-'}</div>
    <div>Color: {currentOil.color ?? '-'}</div>

    <div>Odor: {currentOil.odor ?? '-'}</div>
    <div>Relative Density: {currentOil.relativeDensity ?? '-'}</div>

    <div>Refractive Index: {currentOil.refractiveIndex ?? '-'}</div>
    <div>Optical Rotation: {currentOil.opticalRotation ?? '-'}</div>

    <div>Solubility: {currentOil.solubility ?? '-'}</div>
    <div>Shelf Life: {currentOil.shelfLife ?? '-'}</div>

    <div>Storage Conditions: {currentOil.storageConditions ?? '-'}</div>
    <div></div>
  </div>
</div>

<!-- Product Description -->
<div style="max-width:1400px; margin:20px auto; padding:0 40px; padding-bottom:10px;">
  <h3 style="font-size:24px; color:#4a5d4e; margin-bottom:16px; border-bottom:1px solid #ddd; padding-bottom:10px;">
    Product Description
  </h3>
  <p style="font-size:16px; line-height:1.8; color:#333;">
    {productDescription}
  </p>
</div>

<!-- Blends Well With -->
<div style="max-width:1400px; margin:10px auto; padding:0 40px; padding-bottom:60px;">
  <h3 style="font-size:24px; color:#4a5d4e; margin-bottom:16px; border-bottom:1px solid #ddd; padding-bottom:10px;">
    Blends Well With
  </h3>
  <p style="font-size:16px; line-height:1.8; color:#333;">
    {currentOil.blendsWith || 'Lavender, Rosemary, Eucalyptus, Lemon, Orange'}
  </p>
</div>

    <!-- You Might Also Like -->
    <div style="max-width: 1400px; margin: 20px auto 80px; padding: 0 40px;">
      <h3 style="font-size: 24px; color: #4a5d4e; margin-bottom: 20px; border-bottom: 1px solid #ddd; padding-bottom: 10px;">
        You Might Also Like
      </h3>

      <div style="display: flex; gap: 24px; overflow-x: auto; padding: 10px 5px;">
        {relatedProducts.map(item => (
          <a href={`/products/${item.slug}`} style="flex: 0 0 180px; text-decoration: none; color: inherit;">
            <div style="border-radius: 10px; overflow: hidden; box-shadow: 0 2px 6px rgba(0,0,0,0.1); background: #fff;">
              <img src={item.img} style="width: 100%; height: 240px; object-fit: cover;" alt={item.name}>
              <div style="padding: 12px; text-align: center;">
                <p style="margin:0; font-size: 15px; font-weight: 500;">{item.name}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- ✅ 正常 Footer 全屏修复版 -->
    <div style="width: 100%;">
      <Footer />
    </div>

</body>
</html>