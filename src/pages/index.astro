<!-- Stats Section -->
<section class="bg-white py-12 border-y border-gray-100">
    <div class="max-w-6xl mx-auto px-12 grid grid-cols-1 md:grid-cols-4 gap-8 text-center">
        
        <!-- Item 1 -->
        <div>
            <div class="text-4xl font-bold text-[#4a5d4e] mb-2">11+</div>
            <div class="text-gray-600 font-medium">Years Manufacturing Experience</div>
        </div>

        <!-- Item 2 -->
        <div>
            <div class="text-4xl font-bold text-[#4a5d4e] mb-2">120+</div>
