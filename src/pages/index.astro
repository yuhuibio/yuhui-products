            <button class="w-full bg-[#4a5d4e] text-white py-2 rounded-lg text-sm hover:bg-green-900 transition">Request Quote</button>
        </div>

    </div>
</section>
<!-- Contact Section with Background -->
<section class="py-20 px-12 bg-custom-green"> <!-- 统一使用品牌背景色 -->
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row gap-16 items-start">
        
        <!-- 左侧图片区 -->
        <div class="w-full md:w-1/2">
            <img src="/images/product-showcase.jpg" alt="Contact Us Visual" class="w-full rounded-2xl shadow-lg">
        </div>

        <!-- 右侧表单区 -->
        <div class="w-full md:w-1/2">
            <h2 class="text-3xl font-bold text-[#4a5d4e] mb-8">Contact Us</h2>
            <form action="#" method="POST" class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                    <input type="text" placeholder="Your Name" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-[#4a5d4e] outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" placeholder="Your Email" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-[#4a5d4e] outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Contact No</label>
                    <input type="tel" placeholder="Your Contact Number" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-[#4a5d4e] outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                    <textarea rows="4" placeholder="How can we help you?" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-[#4a5d4e] outline-none"></textarea>
                </div>
                <button type="submit" class="bg-[#4a5d4e] text-white px-10 py-3 rounded-lg font-bold hover:bg-green-900 transition">
                    SUBMIT
                </button>
            </form>
        </div>
    </div>
</section>
