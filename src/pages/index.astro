<!-- About Us Section -->
<section class="bg-[#f2eede] py-20 px-12">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12">
        
        <!-- 左侧图片区 (参考 QQ20260528-103802.jpg) -->
        <div class="w-full md:w-1/2 flex justify-center">
            <img src="/images/about-us.jpg" alt="About Us" class="h-[400px] object-contain">
        </div>

        <!-- 右侧文本区 -->
        <div class="w-full md:w-1/2 text-left">
            <h2 class="text-4xl font-bold text-[#4a5d4e] mb-6">ABOUT US</h2>
            <p class="text-gray-700 leading-relaxed mb-6 text-lg">
                Founded in 2015, XIAN YUHUI BIOTECHNOLOGY CO., LTD. is a professional manufacturer and exporter of high-purity essential oils and plant-based carrier oils. 
            </p>
            <p class="text-gray-700 leading-relaxed mb-8 text-lg">
                We operate integrated production facilities covering raw material sourcing, refining, and quality control. Every stage of production is carefully managed to ensure consistent quality, stable composition, and full batch traceability. Our products are widely supplied to cosmetic formulators, fragrance houses, and industrial manufacturers worldwide.
            </p>
            
            <!-- 仅保留查看详情，去掉 Buy Now -->
            <button class="bg-[#1a1a1a] text-white px-8 py-3 rounded hover:bg-black transition">
                View Full Profile
            </button>
        </div>
    </div>
</section>
<!-- Advantages/Features Section -->
<section class="py-20 px-12 bg-white">
    <div class="max-w-6xl mx-auto text-center mb-16">
        <h2 class="text-4xl font-bold text-[#4a5d4e] mb-4">Why Choose Us</h2>
        <p class="text-gray-600 text-lg">Partnering for quality, innovation, and long-term supply stability.</p>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
        
        <!-- 01 Industry Expertise -->
        <div class="flex flex-col items-center">
            <span class="text-5xl font-extrabold text-gray-200 mb-4">01</span>
            <h3 class="text-2xl font-bold text-[#4a5d4e] mb-4">Industry-Leading Expertise</h3>
            <p class="text-gray-600 leading-relaxed">
                We specialize in high-purity essential oils that meet rigorous international standards. Our reliable supply chain is backed by full documentation (COA/MSDS/TDS) to ensure seamless production compliance.
            </p>
        </div>

        <!-- 02 Direct-Source Advantage -->
        <div class="flex flex-col items-center">
            <span class="text-5xl font-extrabold text-gray-200 mb-4">02</span>
            <h3 class="text-2xl font-bold text-[#4a5d4e] mb-4">Direct-Source Advantage</h3>
            <p class="text-gray-600 leading-relaxed">
                Quality starts at the root. With our 3,000-acre sustainable plantation, we control the entire process from ethical cultivation to advanced extraction, ensuring consistent purity in every batch.
            </p>
        </div>

        <!-- 03 Full Brand Partnership -->
        <div class="flex flex-col items-center">
            <span class="text-5xl font-extrabold text-gray-200 mb-4">03</span>
            <h3 class="text-2xl font-bold text-[#4a5d4e] mb-4">Full Brand Partnership</h3>
            <p class="text-gray-600 leading-relaxed">
                Beyond supply, we are your growth partner. From custom product development and specification guidance to branding strategies, we provide end-to-end support to help you scale your business.
            </p>
        </div>

    </div>
</section>
<section class="py-16 bg-white w-full"> <div class="max-w-6xl mx-auto text-center mb-12 px-12"> <h2 class="text-4xl font-bold text-[#4a5d4e] mb-4">Pure Essence in Every Drop</h2>
        <p class="text-gray-600 text-lg">Witness the precision of our extraction process.</p>
    </div>

    <div class="w-full overflow-hidden">
