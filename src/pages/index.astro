            <button class="w-full bg-[#4a5d4e] text-white py-2 rounded-lg text-sm hover:bg-green-900 transition">Request Quote</button>
        </div>

        <!-- 产品 7: Eucalyptus -->
        <div class="border border-gray-100 rounded-2xl p-5 hover:shadow-lg transition">
            <img src="/images/eucalyptus-oil.jpg" alt="Eucalyptus" class="w-full h-auto object-cover rounded-lg mb-4">
            <h4 class="text-lg font-bold text-gray-900">Eucalyptus oil</h4>
