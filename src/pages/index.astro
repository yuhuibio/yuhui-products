---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const products = [
  { name: "Lavender Essential Oil", image: "lavender-oil.jpg" },
  { name: "Peppermint Oil", image: "peppermint-oil.jpg" },
  { name: "Ginger Oil", image: "ginger-oil.jpg" },
  { name: "Camellia Seed Oil", image: "camellia-seed-oil.jpg" },
  { name: "Frankincense Oil", image: "frankincense-oil.jpg" },
  { name: "Roman Chamomile Oil", image: "chamomile-roman-oil.jpg" },
  { name: "Eucalyptus Oil", image: "eucalyptus-oil.jpg" },
  { name: "Lemon Oil", image: "lemon-oil.jpg" }
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xian Yuhui Biotechnology</title>
  </head>

  <body class="bg-custom-green font-sans">

    <!-- HEADER -->
    <Header />

    <!-- HERO -->
    <section class="flex items-center justify-between px-12 py-16">
      <div class="w-1/2">
        <h1 class="text-6xl font-bold text-[#4a5d4e] mb-6">
          Bulk Essential Oils Supplier for Global Brands
        </h1>
        <p class="text-gray-600 mb-6">
          Pure Natural Oils for Cosmetics & Aromatherapy
        </p>
      </div>

      <div class="w-1/2 flex justify-center">
        <img src="/images/banner-2.jpg" class="h-96 object-contain" />
      </div>
    </section>

    <!-- STATS -->
    <section class="bg-white py-12">
      <div class="max-w-6xl mx-auto grid md:grid-cols-4 text-center">
        <div>
          <div class="text-4xl font-bold text-[#4a5d4e]">11+</div>
          <div>Years Experience</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-[#4a5d4e]">120+</div>
          <div>Products</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-[#4a5d4e]">25–180kg</div>
          <div>Packaging</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-[#4a5d4e]">Global</div>
          <div>Supply</div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="bg-[#f2eede] py-20 px-12">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">

        <img src="/images/about-us.jpg" class="h-[400px] object-contain mx-auto" />

        <div>
          <h2 class="text-4xl font-bold text-[#4a5d4e] mb-6">ABOUT US</h2>

          <p class="text-gray-700 mb-4 text-lg">
            Founded in 2015, XIAN YUHUI BIOTECHNOLOGY CO., LTD. is a professional manufacturer and exporter of high-purity essential oils and plant-based carrier oils.
          </p>

          <p class="text-gray-700 mb-4 text-lg">
            We operate integrated production facilities covering raw material sourcing, refining, and quality control.
          </p>

          <p class="text-gray-700 mb-8 text-lg">
            Our products are widely supplied worldwide to cosmetic, fragrance and industrial markets.
          </p>

          <button class="bg-black text-white px-8 py-3 rounded">
            View Full Profile
          </button>
        </div>

      </div>
    </section>

    <!-- WHY CHOOSE US -->
    <section class="py-20 px-12 bg-white">
      <div class="max-w-6xl mx-auto text-center mb-16">
        <h2 class="text-4xl font-bold text-[#4a5d4e]">Why Choose Us</h2>
      </div>

      <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-12 text-center">

        <div>
          <div class="text-5xl font-extrabold text-gray-500">01</div>
          <h3 class="text-xl font-bold mt-4 text-[#4a5d4e]">Industry Expertise</h3>
          <p class="text-gray-600 mt-2">
            We specialize in high-purity essential oils that meet rigorous international standards. Our reliable supply chain is backed by full documentation (COA/MSDS/TDS) to ensure seamless production compliance.
          </p>
        </div>

        <div>
          <div class="text-5xl font-extrabold text-gray-500">02</div>
          <h3 class="text-xl font-bold mt-4 text-[#4a5d4e]">Direct Source</h3>
          <p class="text-gray-600 mt-2">
            Quality starts at the root. With our 3,000-acre sustainable plantation, we control the entire process from ethical cultivation to advanced extraction, ensuring consistent purity in every batch.
          </p>
        </div>

        <div>
          <div class="text-5xl font-extrabold text-gray-500">03</div>
          <h3 class="text-xl font-bold mt-4 text-[#4a5d4e]">Full Partnership</h3>
          <p class="text-gray-600 mt-2">
            Beyond supply, we are your growth partner. From custom product development and specification guidance to branding strategies, we provide end-to-end support to help you scale your business.
          </p>
        </div>

      </div>
    </section>

    <!-- VIDEO -->
    <section class="py-16 bg-white">
      <div class="max-w-6xl mx-auto text-center mb-6">
        <h2 class="text-4xl font-bold text-[#4a5d4e]">
          Pure Essence in Every Drop
        </h2>
      </div>

      <p class="text-gray-600 text-xl md:text-2xl text-center mb-10 mt-6">
        Witness the precision of our extraction process.
      </p>

      <video class="w-full h-[400px] object-cover" autoplay loop muted playsinline>
        <source src="images/oil-drop.mp4" />
      </video>
    </section>

    <!-- PRODUCTS -->
    <section class="py-20 px-12 bg-white">
      <div class="max-w-7xl mx-auto text-center mb-16">
        <h2 class="text-4xl font-bold text-[#4a5d4e]">Featured Products</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-6">
        {products.map((p) => (
          <div class="border rounded-2xl p-5">
            <img
              src={`/images/${p.image}`}
              class="w-full aspect-square object-contain mb-4"
            />
            <h4 class="text-center font-bold mb-4">
              {p.name}
            </h4>
            <button class="w-full bg-[#4a5d4e] text-white py-2 rounded">
              Request Quote
            </button>
          </div>
        ))}
      </div>
    </section>

    <!-- CONTACT -->
    <section class="py-20 px-12 bg-custom-green">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12">

        <img src="/images/product-showcase.jpg" class="rounded-2xl" />

        <form class="space-y-6">
          <input class="w-full p-3 border rounded" placeholder="Name" />
          <input class="w-full p-3 border rounded" placeholder="Email" />
          <textarea class="w-full p-3 border rounded" rows="4"></textarea>

          <button class="bg-[#4a5d4e] text-white px-10 py-3 rounded">
            SUBMIT
          </button>
        </form>

      </div>
    </section>

    <!-- FOOTER -->
    <Footer />

  </body>
</html>