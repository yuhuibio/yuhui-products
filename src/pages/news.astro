const pageSize = 8;
let currentPage = 1;

// 侧边栏
function renderSidebar(){
    const sideWrap = document.getElementById('recentNewsSidebar');
    const top4 = allNews.slice(0,4);
    let html = '';
    top4.forEach(item=>{
        html += `
        <div class="border-l-4 border-custom-main pl-3">
            <p class="text-xs text-gray-500">${item.date}</p>
            <p class="text-sm font-medium line-clamp-2">${item.title}</p>
        </div>
        `;
    });
    sideWrap.innerHTML = html;
}

// 新闻卡片
function renderGrid(){
    const gridWrap = document.getElementById('newsGrid');
    const start = (currentPage - 1) * pageSize;
    const pageData = allNews.slice(start, start + pageSize);
    let html = '';
    pageData.forEach(item=>{
        html += `
        <div onclick="goDetail(${item.id})" class="bg-white rounded-xl shadow overflow-hidden cursor-pointer hover:scale-[1.02] transition-transform">
            <img src="${item.img}" alt="${item.title}" class="w-full h-60 object-cover">
            <div class="p-6">
                <h3 class="text-lg font-semibold mb-2">${item.title}</h3>
                <p class="text-sm text-gray-500 mb-2">${item.date}</p>
                <p class="text-gray-600 text-sm">${item.desc}</p>
            </div>
        </div>
        `;
    });
    gridWrap.innerHTML = html;
}

// 分页（修复：禁用当前页按钮）
function renderPagination(){
    const totalPages = Math.ceil(allNews.length / pageSize);
    const pageWrap = document.getElementById('paginationBox');
    let html = '';
    for(let i=1; i<=totalPages; i++){
        const isActive = i === currentPage;
        const btnClass = isActive 
            ? 'bg-custom-main text-white cursor-default' 
            : 'border border-gray-300 hover:bg-gray-100';
        html += `<button ${isActive ? 'disabled' : ''} onclick="switchPage(${i})" class="px-4 py-2 rounded ${btnClass}">${i}</button>`;
    }
    pageWrap.innerHTML = html;
}

function switchPage(num){
    currentPage = num;
    renderGrid();
    renderPagination();
}

// 跳详情（增加安全判断）
function goDetail(id) {
    const exist = allNews.some(item => item.id === id);
    if(!exist) return alert('News not found');
    window.location.href = "news-detail.html?id=" + id;
}

// 初始化
document.addEventListener('DOMContentLoaded',()=>{
    renderSidebar();
    renderGrid();
    renderPagination();
});
