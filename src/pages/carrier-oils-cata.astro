---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Carrier Oils | Xian Yuhui Biotechnology">
    
    <!-- Hero Banner -->
    <section class="py-10 mb-16">
        <h2 class="text-center text-4xl font-bold mb-10 text-gray-900">Bulk Carrier Oils</h2>
        <div class="relative w-full overflow-hidden">
            <img src="/images/banner-oils.jpg" alt="Banner" class="w-full h-auto object-cover">
            <div class="absolute inset-0 flex flex-col items-center justify-center text-black text-center px-4">
                <h3 class="text-6xl font-bold uppercase mb-6 tracking-wider">100% Pure & Natural</h3>
                <p class="text-3xl font-normal tracking-wide">Quality You Can Trust | Supply You Can Rely On</p>
            </div>
        </div>
    </section>

    <!-- Main Content Area -->
    <div class="max-w-[1400px] mx-auto px-6 mb-20 flex gap-12">
        
        <!-- Sidebar -->
        <aside class="w-48 flex-shrink-0">
            <ul class="space-y-5" id="filterList">
                <li><a href="#" class="font-bold border-l-2 border-black pl-3 text-black">All Ingredients</a></li>
            </ul>
        </aside>

        <!-- Product Grid -->
        <main class="flex-grow">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="productGrid"></div>
            <div class="flex justify-center mt-12 gap-2" id="pagination"></div>
        </main>
    </div>

    <script is:inline>
        const products = [
            { name: "Sweet Almond Oil", latin: "Prunus amygdalus dulcis", method: "Cold Pressed", img: "/images/sweet-almond-oil.jpg" },
            { name: "Jojoba Oil", latin: "Simmondsia chinensis", method: "Cold Pressed", img: "/images/jojoba-oil.jpg" },
            { name: "Grapeseed Oil", latin: "Vitis vinifera", method: "Cold Pressed", img: "/images/grapeseed-oil.jpg" },
            { name: "Coconut Oil", latin: "Cocos nucifera", method: "Cold Pressed", img: "/images/coconut-oil.jpg" },
            { name: "Argan Oil", latin: "Argania spinosa", method: "Cold Pressed", img: "/images/argan-oil.jpg" },
            { name: "Rosehip Oil", latin: "Rosa canina", method: "Cold Pressed", img: "/images/rosehip-oil.jpg" },
            { name: "Avocado Oil", latin: "Persea americana", method: "Cold Pressed", img: "/images/avocado-oil.jpg" },
            { name: "Olive Oil", latin: "Olea europaea", method: "Cold Pressed", img: "/images/olive-oil.jpg" },
            { name: "Castor Oil", latin: "Ricinus communis", method: "Cold Pressed", img: "/images/castor-oil.jpg" },
            { name: "Evening Primrose Oil", latin: "Oenothera biennis", method: "Cold Pressed", img: "/images/evening-primrose-oil.jpg" },
            { name: "Wheatgerm Oil", latin: "Triticum Vulgare", method: "Cold Pressed", img: "/images/wheatgerm-oil.jpg" },
            { name: "Camellia Seed Oil", latin: "Camellia olelfera Abel", method: "Cold Pressed", img: "/images/camellia-seed-oil.jpg" }
        ];

        function render() {
            const grid = document.getElementById('productGrid');
            grid.innerHTML = products.map(p => `
                <div class="border border-gray-200 p-5 rounded-lg flex flex-col items-center text-center hover:shadow-md transition">
                    <div class="h-64 w-full bg-white mb-4 flex items-center justify-center rounded overflow-hidden">
                        <img src="${p.img}" alt="${p.name}" class="max-h-full max-w-full object-contain" onerror="this.src='https://via.placeholder.com/400x400?text=No+Image'">
                    </div>
                    <h4 class="font-medium text-gray-800">${p.name}</h4>
                    <p class="text-xs text-gray-400 italic mb-1">${p.latin}</p>
                    <p class="text-xs text-gray-500 mb-4">${p.method}</p>
                    <a href="/products/${p.name.toLowerCase().replace(/\s+/g, '-')}" class="w-full bg-[#4a5d4e] text-white py-2 rounded text-center text-xs hover:bg-emerald-900 transition">View Details</a>
                </div>
            `).join('');
        }
        render();
    </script>
</Layout>