---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news');

  return news.map((n) => ({
    params: { slug: n.slug },
    props: { news: n },
  }));
}

const { news } = Astro.props;
const { Content } = await news.render();
---

<Layout title={news.data.title + " | Yuhui Biotechnology"}>

  <!-- BANNER -->
  <section class="h-[250px] flex items-center px-10 bg-[#e5edea]">
    <h1 class="text-2xl md:text-2xl font-bold text-[#4a5d4e]">
      {news.data.title}
    </h1>
  </section>

  <!-- CONTENT -->
  <div class="max-w-4xl mx-auto px-6 py-12">

    <img
      src={news.data.img}
      class="w-full rounded-xl mb-8 shadow-sm"
      alt={news.data.title}
    />

    <p class="text-gray-500 mb-8 font-medium">{news.data.date}</p>

    <!-- 
      这里使用了 prose-lg 自动处理行距和段间距
      prose-a:text-[#00008B] 强制所有链接变为你要求的深蓝色
      prose-headings:text-[#4a5d4e] 让标题颜色与你的 Banner 呼应，更专业
    -->
    <div class="prose prose-lg max-w-none text-gray-700 
                prose-a:text-[#00008B] prose-a:font-semibold prose-a:no-underline hover:prose-a:underline
                prose-headings:text-[#4a5d4e]">
      <Content />
    </div>

  </div>

</Layout>